# =============================================================================
# Enjoy Milk ERP — Environment Variables
# انسخ هذا الملف إلى `.env` واملأ القيم. على Render تُضبط من لوحة التحكم / render.yaml
# =============================================================================

# ─────────── Database ───────────
# محلياً: postgres على جهازك. على Render: تُربط تلقائياً من قاعدة Render
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/enjoymilk?schema=public"

# ─────────── JWT Auth ───────────
# توليد سر قوي:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# على Render: يولّدهما تلقائياً (generateValue)
JWT_SECRET="dev-secret-change-me-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me-different"
JWT_REFRESH_EXPIRES_IN="7d"

# ─────────── App ───────────
NODE_ENV=development
PORT=3001
# عناوين الواجهة المسموح لها (CORS) — مفصولة بفواصل. على Render = رابط الـ web
APP_URL=http://localhost:3000

# ─────────── Telegram Bot (اختياري — بدونه النظام يعمل طبيعياً) ───────────
# 1) أنشئ بوت عبر @BotFather واحصل على التوكن
TELEGRAM_BOT_TOKEN=
# 2) سر للتحقق من صحّة الـ webhook (على Render يُولَّد تلقائياً)
TELEGRAM_WEBHOOK_SECRET=
# 3) معرّفات الدردشات المصرّح لها فقط (مفصولة بفواصل). فارغ = الجميع (غير مُوصى به)
#    لمعرفة معرّفك: راسل البوت بأي رسالة وسيرد بمعرّف الدردشة
TELEGRAM_ALLOWED_CHAT_IDS=
# 4) عنوان الـ API العام لتسجيل الـ webhook تلقائياً.
#    على Render: غير مطلوب — يُستخدم RENDER_EXTERNAL_URL تلقائياً.
#    محلياً مع نفق (ngrok مثلاً): ضع رابط النفق
PUBLIC_API_URL=
# 5) (اختياري) معرّف الـ tenant الافتراضي للبوت. فارغ = أول tenant في القاعدة
TELEGRAM_DEFAULT_TENANT_ID=

# ─────────── Frontend ───────────
# على Render = رابط الـ api العام (https://enjoymilk-api.onrender.com)
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_NAME="Enjoy Milk ERP"
