// =============================================================================
// Enjoy Milk ERP — Prisma Schema (MVP Production-Ready)
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── CORE ──────────────────────────────────────────────────────────────

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  legalName String?
  currency  String   @default("JOD")
  timezone  String   @default("Asia/Amman")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  users User[]
}

model User {
  id           String    @id @default(cuid())
  tenantId     String
  email        String    @unique
  fullName     String
  passwordHash String
  role         UserRole  @default(OPERATOR)
  active       Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  sessions Session[]

  @@index([tenantId, active])
}

enum UserRole {
  OWNER
  ADMIN
  MANAGER
  ACCOUNTANT
  WAREHOUSE
  OPERATOR
  HR
}

model Session {
  id           String    @id @default(cuid())
  userId       String
  refreshToken String    @unique
  ip           String?
  userAgent    String?
  expiresAt    DateTime
  revokedAt    DateTime?
  createdAt    DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── INVENTORY ─────────────────────────────────────────────────────────

model Warehouse {
  id        String        @id @default(cuid())
  tenantId  String
  code      String
  name      String
  type      WarehouseType @default(GENERAL)
  active    Boolean       @default(true)
  createdAt DateTime      @default(now())

  stockLevels   StockLevel[]
  movementsFrom StockMovement[] @relation("MovementFrom")
  movementsTo   StockMovement[] @relation("MovementTo")

  @@unique([tenantId, code])
}

enum WarehouseType {
  POWDER_BULK       // بودرة مستوردة
  PACKAGING         // مواد تغليف
  FINISHED_GOODS    // منتجات جاهزة
  QUARANTINE        // حجر صحي
  GENERAL
}

model Item {
  id              String           @id @default(cuid())
  tenantId        String
  sku             String
  barcode         String?
  name            String
  type            ItemType
  unit            String           @default("PCS")
  netWeightGrams  Int?
  packagingFormat PackagingFormat?
  packsPerCarton  Int?
  shelfLifeDays   Int?
  reorderLevel    Decimal?         @db.Decimal(18, 4)
  costPrice       Decimal?         @db.Decimal(18, 4)
  sellPrice       Decimal?         @db.Decimal(18, 2)

  // ─── Enterprise inventory settings ───
  minStock              Decimal? @db.Decimal(18, 4)   // الحد الأدنى
  maxStock              Decimal? @db.Decimal(18, 4)   // الحد الأقصى
  reorderPoint          Decimal? @db.Decimal(18, 4)   // نقطة إعادة الطلب
  productionReorderLevel Decimal? @db.Decimal(18, 4)  // نقطة إعادة طلب الإنتاج (تخطيط إنتاجي)
  reorderQty            Decimal? @db.Decimal(18, 4)   // كمية إعادة الطلب
  safetyStock           Decimal? @db.Decimal(18, 4)   // مخزون الأمان
  leadTimeDays          Int?                          // مدة التوريد

  // ─── Cost & sales tracking (auto-updated) ───
  lastPurchasePrice Decimal?       @db.Decimal(18, 4)
  avgCost           Decimal?       @db.Decimal(18, 4)
  lastPurchaseAt    DateTime?
  lastSaleAt        DateTime?

  // ─── Extended metadata for the inline "add material" modal ───
  nameEn             String?             // الاسم بالإنجليزي (اختياري)
  category           String?             // التصنيف
  notes              String?             // ملاحظات
  defaultSupplierId  String?             // المورد الافتراضي (Supplier.id)
  bagWeightKg        Decimal? @db.Decimal(18, 4)  // وزن الشوال (25 كغ لحليب)
  gramsPerUnit       Decimal? @db.Decimal(18, 4)  // للتحويل غرام↔كغ

  active          Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  batches      Batch[]
  stockLevels  StockLevel[]
  movements    StockMovement[]
  formulas     PackagingFormulaItem[]
  outputItem   PackagingFormula[]     @relation("formulaOutput")
  adjustments  StockAdjustment[]
  receipts     StockReceipt[]

  @@unique([tenantId, sku])
  @@index([tenantId, type, active])
  @@index([barcode])
}

// ─── الموردون ──────────────────────────────────────────
model Supplier {
  id        String   @id @default(cuid())
  tenantId  String
  code      String?
  name      String
  phone     String?
  email     String?
  address   String?
  notes     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  receipts StockReceipt[]

  @@index([tenantId, active])
}

// ─── تعديلات المخزون اليدوية ───────────────────────────
// أنواع العمليات:
//   ADD             إضافة كمية
//   DEDUCT          خصم كمية
//   CORRECTION      تصحيح كمية (yield delta)
//   COUNT           جرد (تعيين قيمة مطلقة)
//   DAMAGE          إتلاف
//   LOSS            فقدان
//   EXPIRY          انتهاء صلاحية
//   SUPPLIER_RETURN إرجاع للمورد
//   TRANSFER_OUT    خرج تحويل
//   TRANSFER_IN     دخل تحويل
model StockAdjustment {
  id            String   @id @default(cuid())
  tenantId      String
  itemId        String
  warehouseId   String
  type          String              // ADD | DEDUCT | CORRECTION | COUNT | DAMAGE | LOSS | EXPIRY | SUPPLIER_RETURN | TRANSFER_OUT | TRANSFER_IN
  quantity      Decimal  @db.Decimal(18, 4)   // الدلتا (موجب/سالب) أو القيمة الجديدة عند COUNT
  quantityBefore Decimal? @db.Decimal(18, 4)
  quantityAfter  Decimal? @db.Decimal(18, 4)
  reason        String              // سبب رئيسي (مطلوب)
  notes         String?
  imageUrl      String?             // مرفق (اختياري)
  refType       String?             // مرجع (transfer / receipt / ...)
  refId         String?
  status        String   @default("APPROVED")  // PENDING | APPROVED | REJECTED
  performedById String?
  approvedById  String?
  createdAt     DateTime @default(now())

  item      Item      @relation(fields: [itemId], references: [id])

  @@index([tenantId, createdAt])
  @@index([itemId, createdAt])
}

// ─── تحويل مخزون بين المستودعات (مع موافقة) ─────────
// الحالات:
//   PENDING   طلب تحويل بانتظار الموافقة
//   APPROVED  تمت الموافقة (تُنفَّذ الحركة تلقائياً)
//   REJECTED  مرفوض
//   COMPLETED منتهي
//   CANCELLED ملغي
model StockTransfer {
  id              String    @id @default(cuid())
  tenantId        String
  number          String                              // TRF-YYYY-XXXX
  itemId          String
  fromWarehouseId String
  toWarehouseId   String
  quantity        Decimal   @db.Decimal(18, 4)
  status          String    @default("PENDING")
  notes           String?
  requestedById   String?
  approvedById    String?
  approvedAt      DateTime?
  rejectedReason  String?
  executedAt      DateTime?                            // متى تُنفِّذ الحركة على المخزون
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([tenantId, number])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
}

// ─── جرد المخزون (Inventory Count) ──────────────────
// الحالات:
//   DRAFT       مسودة
//   IN_PROGRESS جرد قيد التنفيذ
//   COMPLETED   انتهى الجرد (لم يُعتمَد بعد)
//   APPROVED    اعتُمِد + طُبِّقت الفروقات على المخزون
//   CANCELLED   ملغي
model InventoryCount {
  id           String    @id @default(cuid())
  tenantId     String
  number       String                              // CNT-YYYY-XXXX
  warehouseId  String?                             // null = كل المستودعات
  scheduledAt  DateTime?
  status       String    @default("DRAFT")
  frozen       Boolean   @default(false)           // تجميد الحركات (اختياري)
  notes        String?
  createdById  String?
  approvedById String?
  approvedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  lines InventoryCountLine[]

  @@unique([tenantId, number])
  @@index([tenantId, status])
}

model InventoryCountLine {
  id          String    @id @default(cuid())
  tenantId    String
  countId     String
  itemId      String
  warehouseId String
  expectedQty Decimal   @db.Decimal(18, 4)          // ما هو في النظام لحظة الجرد
  actualQty   Decimal?  @db.Decimal(18, 4)          // الجرد الفعلي
  variance    Decimal?  @db.Decimal(18, 4)          // actual - expected
  notes       String?
  countedById String?
  countedAt   DateTime?

  count InventoryCount @relation(fields: [countId], references: [id], onDelete: Cascade)

  @@index([countId])
  @@index([itemId])
}

// ─── استلام مخزون جديد ────────────────────────────────
// المصادر: SUPPLIER | MANUAL | TRANSFER_IN | CUSTOMER_RETURN | PRODUCTION
model StockReceipt {
  id                  String    @id @default(cuid())
  tenantId            String
  itemId              String
  warehouseId         String
  source              String                  // SUPPLIER | MANUAL | TRANSFER_IN | CUSTOMER_RETURN | PRODUCTION
  quantity            Decimal   @db.Decimal(18, 4)
  unitCost            Decimal?  @db.Decimal(18, 4)
  supplierId          String?
  invoiceNumber       String?
  purchaseOrderNumber String?
  batchNumber         String?
  serialNumber        String?
  productionDate      DateTime?
  expiryDate          DateTime?
  notes               String?
  performedById       String?
  createdAt           DateTime  @default(now())

  item     Item      @relation(fields: [itemId], references: [id])
  supplier Supplier? @relation(fields: [supplierId], references: [id])

  @@index([tenantId, createdAt])
  @@index([itemId, createdAt])
  @@index([supplierId])
}

enum ItemType {
  POWDER_BULK     // البودرة المستوردة
  PACKAGING       // كراتين، أكياس، تينات
  POWDER_RETAIL   // المنتج النهائي المعبّأ
  CONSUMABLE      // مستهلكات
}

enum PackagingFormat {
  SACHET
  TIN
  POUCH
  JAR
  BULK_BAG
}

model Batch {
  id             String    @id @default(cuid())
  tenantId       String
  itemId         String
  code           String
  productionDate DateTime?
  expiryDate     DateTime?
  qcStatus       QcStatus  @default(PASSED)
  notes          String?
  createdAt      DateTime  @default(now())

  item        Item            @relation(fields: [itemId], references: [id])
  stockLevels StockLevel[]
  movements   StockMovement[]

  @@unique([tenantId, code])
  @@index([itemId, expiryDate])
}

enum QcStatus {
  PENDING
  PASSED
  FAILED
  ON_HOLD
}

model StockLevel {
  id          String   @id @default(cuid())
  tenantId    String
  itemId      String
  warehouseId String
  batchId     String?
  quantity    Decimal  @db.Decimal(18, 4) @default(0)
  updatedAt   DateTime @updatedAt

  item      Item      @relation(fields: [itemId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  batch     Batch?    @relation(fields: [batchId], references: [id])

  @@unique([itemId, warehouseId, batchId])
  @@index([tenantId, warehouseId])
}

model StockMovement {
  id              String       @id @default(cuid())
  tenantId        String
  type            MovementType
  itemId          String
  batchId         String?
  fromWarehouseId String?
  toWarehouseId   String?
  quantity        Decimal      @db.Decimal(18, 4)
  reasonCode      String?
  refType         String?
  refId           String?
  notes           String?
  performedById   String?
  performedAt     DateTime     @default(now())

  item          Item       @relation(fields: [itemId], references: [id])
  batch         Batch?     @relation(fields: [batchId], references: [id])
  fromWarehouse Warehouse? @relation("MovementFrom", fields: [fromWarehouseId], references: [id])
  toWarehouse   Warehouse? @relation("MovementTo", fields: [toWarehouseId], references: [id])

  @@index([tenantId, performedAt])
  @@index([itemId, performedAt])
}

enum MovementType {
  IN
  OUT
  TRANSFER
  ADJUSTMENT
  WASTE
  RETURN
}

// ─── REPACKAGING (الإنتاج) ─────────────────────────────────────────────

model ProductionLine {
  id        String   @id @default(cuid())
  tenantId  String
  code      String
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  machines     Machine[]
  repackOrders RepackOrder[]

  @@unique([tenantId, code])
}

model Machine {
  id              String      @id @default(cuid())
  tenantId        String
  lineId          String
  code            String
  name            String
  type            MachineType?
  capacityPerHour Decimal?    @db.Decimal(18, 4)
  active          Boolean     @default(true)
  createdAt       DateTime    @default(now())

  line       ProductionLine @relation(fields: [lineId], references: [id])
  repackRuns RepackRun[]

  @@unique([tenantId, code])
}

enum MachineType {
  SACHET_FILLER
  TIN_FILLER
  POUCH_FILLER
  CARTONING
  LABELING
  WEIGHING
  METAL_DETECTOR
}

model PackagingFormula {
  id           String   @id @default(cuid())
  tenantId     String
  code         String
  name         String
  outputItemId String
  outputQty    Decimal  @db.Decimal(18, 4)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())

  outputItem   Item                   @relation("formulaOutput", fields: [outputItemId], references: [id])
  items        PackagingFormulaItem[]
  repackOrders RepackOrder[]

  @@unique([tenantId, code])
}

model PackagingFormulaItem {
  id        String  @id @default(cuid())
  formulaId String
  itemId    String
  quantity  Decimal @db.Decimal(18, 4)
  unit      String
  isPrimary Boolean @default(false)

  formula PackagingFormula @relation(fields: [formulaId], references: [id], onDelete: Cascade)
  item    Item             @relation(fields: [itemId], references: [id])

  @@index([formulaId])
}

model RepackOrder {
  id          String            @id @default(cuid())
  tenantId    String
  number      String
  formulaId   String
  lineId      String
  plannedQty  Decimal           @db.Decimal(18, 4)
  status      RepackOrderStatus @default(PLANNED)
  notes       String?
  createdById String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  formula PackagingFormula @relation(fields: [formulaId], references: [id])
  line    ProductionLine   @relation(fields: [lineId], references: [id])
  runs    RepackRun[]

  @@unique([tenantId, number])
  @@index([tenantId, status])
}

enum RepackOrderStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model RepackRun {
  id              String          @id @default(cuid())
  tenantId        String
  orderId         String
  machineId       String
  startedAt       DateTime        @default(now())
  endedAt         DateTime?
  outputUnits     Decimal         @db.Decimal(18, 4) @default(0)
  wasteUnits      Decimal         @db.Decimal(18, 4) @default(0)
  downtimeMinutes Int             @default(0)
  yieldPct        Decimal?        @db.Decimal(7, 4)
  status          RepackRunStatus @default(IN_PROGRESS)
  notes           String?
  startedById     String?
  endedById       String?

  order   RepackOrder @relation(fields: [orderId], references: [id])
  machine Machine     @relation(fields: [machineId], references: [id])

  @@index([tenantId, startedAt])
  @@index([machineId, status])
}

enum RepackRunStatus {
  IN_PROGRESS
  COMPLETED
  ABORTED
}

// ─── CUSTOMERS & SALES ─────────────────────────────────────────────────

model Customer {
  id           String   @id @default(cuid())
  tenantId     String
  code         String
  name         String
  type         String   @default("RETAIL")
  phone        String?
  email        String?
  address      String?
  creditLimit  Decimal  @db.Decimal(18, 2) @default(0)
  paymentTerms Int      @default(0)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orders   SalesOrder[]
  payments Payment[]

  @@unique([tenantId, code])
  @@index([tenantId, active])
}

model SalesOrder {
  id           String           @id @default(cuid())
  tenantId     String
  number       String
  customerId   String
  orderDate    DateTime         @default(now())
  deliveryDate DateTime?
  status       SalesOrderStatus @default(DRAFT)
  subtotal     Decimal          @db.Decimal(18, 2) @default(0)
  total        Decimal          @db.Decimal(18, 2) @default(0)
  paid         Decimal          @db.Decimal(18, 2) @default(0)
  balance      Decimal          @db.Decimal(18, 2) @default(0)
  notes        String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  customer Customer    @relation(fields: [customerId], references: [id])
  lines    OrderLine[]
  payments Payment[]

  @@unique([tenantId, number])
  @@index([tenantId, customerId, status])
}

enum SalesOrderStatus {
  DRAFT
  CONFIRMED
  DELIVERED
  PAID
  CANCELLED
}

model OrderLine {
  id        String  @id @default(cuid())
  orderId   String
  itemId    String
  quantity  Decimal @db.Decimal(18, 4)
  unitPrice Decimal @db.Decimal(18, 2)
  lineTotal Decimal @db.Decimal(18, 2)

  order SalesOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model Payment {
  id           String        @id @default(cuid())
  tenantId     String
  customerId   String
  orderId      String?
  number       String
  amount       Decimal       @db.Decimal(18, 2)
  method       PaymentMethod @default(CASH)
  cashboxId    String?
  receivedAt   DateTime      @default(now())
  notes        String?
  receivedById String?

  customer Customer    @relation(fields: [customerId], references: [id])
  order    SalesOrder? @relation(fields: [orderId], references: [id])
  cashbox  Cashbox?    @relation(fields: [cashboxId], references: [id])

  @@unique([tenantId, number])
  @@index([tenantId, customerId])
}

enum PaymentMethod {
  CASH
  CHEQUE
  BANK_TRANSFER
  CARD
}

// ─── FINANCE ───────────────────────────────────────────────────────────

model Cashbox {
  id        String   @id @default(cuid())
  tenantId  String
  code      String
  name      String
  balance   Decimal  @db.Decimal(18, 2) @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  movements CashMovement[]
  payments  Payment[]

  @@unique([tenantId, code])
}

model CashMovement {
  id            String           @id @default(cuid())
  tenantId      String
  cashboxId     String
  type          CashMovementType
  amount        Decimal          @db.Decimal(18, 2)
  description   String?
  refType       String?
  refId         String?
  performedById String?
  performedAt   DateTime         @default(now())

  cashbox Cashbox @relation(fields: [cashboxId], references: [id])

  @@index([tenantId, cashboxId, performedAt])
}

enum CashMovementType {
  IN
  OUT
  TRANSFER
}

model Cheque {
  id         String       @id @default(cuid())
  tenantId   String
  type       ChequeType
  number     String
  bankName   String?
  amount     Decimal      @db.Decimal(18, 2)
  issueDate  DateTime
  dueDate    DateTime
  status     ChequeStatus @default(IN_HAND)
  customerId String?
  notes      String?
  createdAt  DateTime     @default(now())

  @@unique([tenantId, type, number])
  @@index([tenantId, status, dueDate])
}

enum ChequeType {
  RECEIVED
  ISSUED
}

enum ChequeStatus {
  IN_HAND
  DEPOSITED
  CASHED
  RETURNED
  CANCELLED
}

model Expense {
  id          String   @id @default(cuid())
  tenantId    String
  number      String
  category    String
  amount      Decimal  @db.Decimal(18, 2)
  description String
  expenseDate DateTime @default(now())
  cashboxId   String?
  createdById String?
  createdAt   DateTime @default(now())

  // ─── دعم عدة عملات ────────────────────────────
  currency      String   @default("JOD")
  exchangeRate  Decimal  @db.Decimal(18, 6) @default(1)
  amountInBase  Decimal  @db.Decimal(18, 3) @default(0)

  @@unique([tenantId, number])
  @@index([tenantId, expenseDate])
}

// ─── HR ────────────────────────────────────────────────────────────────

model Employee {
  id                 String    @id @default(cuid())
  tenantId           String
  code               String
  fullName           String
  nationalId         String?
  phone              String?
  email              String?
  department         String?
  position           String?
  hireDate           DateTime?
  // NOTE: precision kept at (18,2) لتفادي أي مشاكل migration على الأعمدة الحالية
  // الحسابات في الـ backend تُقرِّب لـ 3 خانات في المخرجات فقط.
  baseSalary         Decimal?  @db.Decimal(18, 2)
  // ─── بدل مواصلات افتراضي (حقل جديد — نستخدم 18,3 للدقة على JOD) ─
  transportAllowance Decimal   @db.Decimal(18, 3) @default(0)
  notes              String?
  active             Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  attendance AttendanceRecord[]
  documents  EmployeeDocument[]
  advances   EmployeeAdvance[]

  @@unique([tenantId, code])
  @@index([tenantId, active])
}

// ─── سلف الموظفين (Advances / Loans) ─────────────────
// السلفة تُنشأ بمبلغ كامل وعدد أقساط. كل شهر يُخصم قسط واحد
// (installmentAmount) من راتب الموظف حتى ينفد المبلغ. يمنع الخصم
// المكرر عن طريق تسجيل الشهور المخصومة في AdvanceInstallment.
model EmployeeAdvance {
  id                 String   @id @default(cuid())
  tenantId           String
  employeeId         String
  amount             Decimal  @db.Decimal(18, 3)   // المبلغ الكلي
  installmentAmount  Decimal  @db.Decimal(18, 3)   // قسط شهري
  installmentsCount  Int                            // عدد الأقساط الكلي
  paidAmount         Decimal  @db.Decimal(18, 3) @default(0)
  status             String   @default("ACTIVE")   // ACTIVE | CLOSED | CANCELLED
  notes              String?
  startMonth         String                        // "YYYY-MM" — أول شهر خصم
  createdById        String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  employee     Employee               @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  installments AdvanceInstallment[]

  @@index([tenantId, employeeId])
  @@index([tenantId, status])
}

// سجل خصم قسط سلفة في شهر معيّن — يمنع الخصم المزدوج
model AdvanceInstallment {
  id         String   @id @default(cuid())
  tenantId   String
  advanceId  String
  month      String                                 // "YYYY-MM"
  amount     Decimal  @db.Decimal(18, 3)
  createdAt  DateTime @default(now())

  advance EmployeeAdvance @relation(fields: [advanceId], references: [id], onDelete: Cascade)

  @@unique([advanceId, month])
  @@index([tenantId, month])
}

// ─── ملفات الموظف (وثائق) ─────────────────────────────
// أنواع مدعومة: WARNING (تنبيه) | CONTRACT (عقد) | DECLARATION (إقرار) | RESIGNATION (استقالة) | OTHER
model EmployeeDocument {
  id          String   @id @default(cuid())
  tenantId    String
  employeeId  String
  docType     String   @default("OTHER")
  title       String
  fileName    String?
  mimeType    String?
  fileData    String?  @db.Text            // base64 (لملفات صغيرة) — بديل عن التخزين السحابي
  fileUrl     String?                       // رابط خارجي بديل
  description String?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([tenantId, employeeId])
  @@index([employeeId, docType])
}

model AttendanceRecord {
  id          String           @id @default(cuid())
  tenantId    String
  employeeId  String
  date        DateTime         @db.Date
  checkIn     DateTime?
  checkOut    DateTime?
  lateMin     Int              @default(0)
  overtimeMin Int              @default(0)
  status      AttendanceStatus @default(PRESENT)
  notes       String?

  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, date])
  @@index([tenantId, date])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LEAVE
  LATE
  HALF_DAY
  HOLIDAY
}

// ── تعديلات الرواتب اليدوية (مكافآت/خصومات/تجاوز يدوي/ملاحظات) ──
// سجل واحد لكل موظف لكل شهر. يُطبَّق فوق الحساب التلقائي في كشف الرواتب.
model PayrollAdjustment {
  id                 String    @id @default(cuid())
  tenantId           String
  employeeId         String
  month              String              // "2026-05"
  // NOTE: الأعمدة الموجودة مسبقاً تبقى (18,2) لتفادي مشاكل migration؛
  // الأعمدة الجديدة تستخدم (18,3) للدقة على الدينار الأردني.
  bonus              Decimal   @db.Decimal(18, 2) @default(0)   // مكافأة
  deduction          Decimal   @db.Decimal(18, 2) @default(0)   // خصم يدوي إضافي
  overrideNet        Decimal?  @db.Decimal(18, 2)               // تجاوز الصافي بالكامل
  // ─── حقول محاسبية ممتدة (جديدة — 18,3) ─────────
  overtimeAmount     Decimal?  @db.Decimal(18, 3)               // تجاوز يدوي لأجر العمل الإضافي
  transportOverride  Decimal?  @db.Decimal(18, 3)               // بدل مواصلات مخصص لهذا الشهر
  extraDeductions    Decimal   @db.Decimal(18, 3) @default(0)   // خصومات موظف معتمدة أخرى
  employeeSSOverride Decimal?  @db.Decimal(18, 3)               // تجاوز يدوي لضمان الموظف
  overrideReason     String?                                     // سبب أي تجاوز يدوي (للـ audit)
  notes              String?                                     // ملاحظات على راتب الشهر
  paid               Boolean   @default(false)
  paidAt             DateTime?
  cashboxId          String?
  createdById        String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([tenantId, employeeId, month])
  @@index([tenantId, month])
}

// ─── COMPLIANCE ────────────────────────────────────────────────────────

model License {
  id                   String        @id @default(cuid())
  tenantId             String
  type                 String
  number               String
  issueDate            DateTime
  expiryDate           DateTime
  status               LicenseStatus @default(VALID)
  notes                String?
  // ─── حقول ممتدة للتعديل ───────────────────────────
  issuingAuthority     String?       // الجهة المصدرة
  renewalReminderDays  Int?          // عدد أيام التذكير قبل الانتهاء
  attachmentUrl        String?       // رابط مرفق (أو data URL)
  attachmentName       String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@unique([tenantId, type, number])
  @@index([tenantId, expiryDate])
}

enum LicenseStatus {
  VALID
  EXPIRING_SOON
  EXPIRED
}

// ─── AUDIT ─────────────────────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String
  actorUserId String?
  action      String
  resource    String
  resourceId  String?
  before      Json?
  after       Json?
  ip          String?
  userAgent   String?             // معلومات المتصفح/الجهاز
  method      String?             // POST | PATCH | PUT | DELETE
  path        String?             // كامل المسار
  status      Int?                // HTTP status
  occurredAt  DateTime @default(now())

  @@index([tenantId, resource, occurredAt])
  @@index([tenantId, actorUserId, occurredAt])
}

// ═══════════════════════════════════════════════════════════════════════════
// ── DAILY PRODUCTION (ورقة الإنتاج اليومية) ─────────────────────────────
// ═══════════════════════════════════════════════════════════════════════════
// تنظيم الأقسام:
//   1) المواد المسحوبة من المستودع الخام:
//      - الكرتون  (CartonUsage)
//      - الألمنيوم (AluminumUsage)
//      - الحليب   (MilkUsage)
//   2) المواد المنتجة      (ProducedItem)
//   3) التوالف              (ProductionWaste)
//   4) ملاحظات              (حقل notes في DailyProduction)
//
// عند POST:
//   • خصم كل المواد الخام من المخزون
//   • إضافة المواد المنتجة لمخزون المنتجات الجاهزة
//   • خصم التوالف من المخزون
//   • حساب رصيد المخزون بعد الإنتاج تلقائياً
// ═══════════════════════════════════════════════════════════════════════════

model DailyProduction {
  id             String   @id @default(cuid())
  tenantId       String
  productionDate DateTime @db.Date
  shift          String?
  operatorName   String?
  operatorId     String?
  machineNumber  Int?              // اختياري — يمكن ربط الورقة بماكينة محددة
  notes          String?           // ملاحظات (textarea كبير)
  status         String   @default("DRAFT")  // DRAFT | POSTED | CANCELLED
  postedAt       DateTime?
  postedById     String?
  createdById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  cartonUsage   ProductionCartonUsage[]
  aluminumUsage ProductionAluminumUsage[]
  milkUsage     ProductionMilkUsage[]
  produced      ProductionProducedItem[]
  wastages      ProductionWaste[]

  @@index([tenantId, productionDate])
  @@index([tenantId, status])
}

// ── (1) الكرتون المسحوب من المستودع الخام ─────────────────
model ProductionCartonUsage {
  id                String  @id @default(cuid())
  tenantId          String
  dailyProductionId String
  itemId            String?            // ربط بصنف من المخزون (اختياري)
  itemName          String             // اسم الصنف (نص حر)
  quantity          Decimal @db.Decimal(18, 4)
  warehouseId       String?

  dailyProduction DailyProduction @relation(fields: [dailyProductionId], references: [id], onDelete: Cascade)

  @@index([dailyProductionId])
  @@index([tenantId, itemId])
}

// ── (2) الألمنيوم المسحوب من المستودع الخام ───────────────
model ProductionAluminumUsage {
  id                String  @id @default(cuid())
  tenantId          String
  dailyProductionId String
  itemId            String?
  itemName          String
  quantity          Decimal @db.Decimal(18, 4)
  warehouseId       String?

  dailyProduction DailyProduction @relation(fields: [dailyProductionId], references: [id], onDelete: Cascade)

  @@index([dailyProductionId])
  @@index([tenantId, itemId])
}

// ── (3) الحليب الخام المسحوب (عدد + كمية) ────────────────
model ProductionMilkUsage {
  id                String  @id @default(cuid())
  tenantId          String
  dailyProductionId String
  itemId            String?
  itemName          String?            // اختياري — للسهولة
  count             Int     @default(0)         // العدد (عدد العبوات/البراميل)
  quantity          Decimal @db.Decimal(18, 4)  // الكمية (لتر / كغ)
  unit              String  @default("L")
  warehouseId       String?

  dailyProduction DailyProduction @relation(fields: [dailyProductionId], references: [id], onDelete: Cascade)

  @@index([dailyProductionId])
  @@index([tenantId, itemId])
}

// ── (4) المواد المنتجة (الصنف + عدد الطبالي + مجموع الكراتين) ─
// machineNumber اختياري لكل سطر — يسمح بنفس المنتج على ماكينات مختلفة في نفس اليوم
model ProductionProducedItem {
  id                String  @id @default(cuid())
  tenantId          String
  dailyProductionId String
  itemId            String?            // ربط بمنتج من المخزون
  itemName          String             // الصنف
  palletsCount      Int     @default(0)  // عدد الطبالي
  cartonsTotal      Int     @default(0)  // مجموع الكراتين
  machineNumber     Int?               // رقم ماكينة هذا السطر (يدعم تعدد الماكينات لنفس المنتج)
  warehouseId       String?
  notes             String?

  dailyProduction DailyProduction @relation(fields: [dailyProductionId], references: [id], onDelete: Cascade)

  @@index([dailyProductionId])
  @@index([tenantId, itemId])
  @@index([tenantId, machineNumber])
}

// ── (5) التوالف ────────────────────────────────────────────
model ProductionWaste {
  id                String  @id @default(cuid())
  tenantId          String
  dailyProductionId String
  itemId            String?
  itemName          String             // الصنف
  quantity          Decimal @db.Decimal(18, 4)  // العدد / الوزن
  unit              String  @default("PCS")    // PCS | KG | L
  warehouseId       String?
  reason            String?

  dailyProduction DailyProduction @relation(fields: [dailyProductionId], references: [id], onDelete: Cascade)

  @@index([dailyProductionId])
  @@index([tenantId, itemId])
}

// ═══════════════════════════════════════════════════════════════════════════
// ── TELEGRAM (ربط متعدد لحسابات/بوتات تيليغرام) ──────────────────────
// ═══════════════════════════════════════════════════════════════════════════
// يدعم ربط أكثر من بوت/حساب بنفس النظام. كل حساب له توكنه الخاص،
// سرّ webhook خاص، صلاحيات (دور)، وحالة اتصال. يُستخدم AsyncLocalStorage
// في الخدمة لتمرير سياق الحساب (التوكن/المنشأة/الدور) لكل تحديث وارد.

enum TelegramRole {
  ADMIN       // كل الصلاحيات
  MANAGER     // المالية + الموظفين + الإنتاج + التقارير
  EMPLOYEE    // تسجيل الدوام + إدخال الإنتاج + التقارير
  VIEWER      // عرض التقارير فقط
}

enum TelegramStatus {
  PENDING       // أُضيف ولم يُختبر بعد
  CONNECTED     // متصل والـ webhook مُسجَّل
  DISCONNECTED  // تعذّر الاتصال
  DISABLED      // مُعطَّل يدوياً
  ERROR         // خطأ (توكن غير صحيح مثلاً)
}

model TelegramAccount {
  id             String         @id @default(cuid())
  tenantId       String
  name           String                          // اسم الحساب/البوت
  token          String                          // Bot Token (حسّاس — يُحجب عند العرض)
  chatId         String?                         // الدردشة الافتراضية للإرسال
  username       String?                         // @username
  botUsername    String?                         // يُجلب تلقائياً من getMe
  phone          String?                         // رقم الهاتف (اختياري)
  accountType    String         @default("BOT")  // BOT | USER | CHANNEL | GROUP
  role           TelegramRole   @default(VIEWER)
  status         TelegramStatus @default(PENDING)
  webhookSecret  String                          // سرّ webhook خاص بهذا الحساب
  webhookSet     Boolean        @default(false)
  notes          String?
  active         Boolean        @default(true)
  lastActivityAt DateTime?                        // آخر نشاط (تحديث وارد)
  lastMessageAt  DateTime?                        // آخر رسالة مستلمة
  lastSyncAt     DateTime?                        // آخر اختبار/مزامنة ناجحة
  lastError      String?
  createdById    String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  logs TelegramLog[]

  @@index([tenantId, active])
}

model TelegramLog {
  id        String   @id @default(cuid())
  tenantId  String
  accountId String?
  direction String              // IN | OUT | SYSTEM
  action    String              // اسم الأمر / الحدث
  summary   String?
  chatId    String?
  success   Boolean  @default(true)
  error     String?
  createdAt DateTime @default(now())

  account TelegramAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([accountId, createdAt])
}

// ── ماكينات الإنتاج (قائمة قابلة للإدارة) ─────────────────
// قائمة بسيطة لإدارة الماكينات (إضافة/تعديل/حذف). ورقة الإنتاج
// تخزّن رقم الماكينة (machineNumber) — وهذه القائمة تُغذّي القائمة المنسدلة.
model ProductionMachine {
  id        String   @id @default(cuid())
  tenantId  String
  number    Int                 // رقم الماكينة (1، 2، 3 ...)
  name      String              // اسم/وصف الماكينة
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, number])
  @@index([tenantId, active])
}

// ═══════════════════════════════════════════════════════════════════════════
// ── SIMPLE ORDERS (طلبيات مبسّطة — بدون فواتير) ───────────────────────
// ═══════════════════════════════════════════════════════════════════════════
// طلبية بسيطة: اسم العميل + هاتف + منطقة + منتجات + مدفوع/متبقي
// خصم المخزون فوراً عند الإنشاء، إرجاع عند الحذف/التعديل
// ═══════════════════════════════════════════════════════════════════════════

model SimpleOrder {
  id            String   @id @default(cuid())
  tenantId      String
  number        String              // ORD-2026-001
  customerId    String?             // اختياري — ربط مع Customer
  customerName  String              // نص حر للسهولة
  customerPhone String?
  region        String?             // المنطقة
  orderDate     DateTime  @default(now())
  total         Decimal  @db.Decimal(18, 2) @default(0)
  paid          Decimal  @db.Decimal(18, 2) @default(0)
  balance       Decimal  @db.Decimal(18, 2) @default(0)
  status        String   @default("UNPAID")  // UNPAID | PARTIAL | PAID | CANCELLED
  notes         String?
  createdById   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // ─── تقسيم الطلبيات + بيانات الشحن ───
  orderType             String   @default("INTERNAL")  // INTERNAL | EXTERNAL
  contractNumber        String?
  deliveryLocation      String?
  expectedShippingDate  DateTime?
  expectedArrivalDate   DateTime?
  shipmentTrackingNumber String?

  // ─── الحقول المالية الجديدة (Ton pricing + Shipping) ───
  // tonPrice على مستوى الطلبية يُستخدم كسعر افتراضي للأسطر التي لا تُحدّد
  // سعر خاص بها. shippingCost يُضاف إلى إجمالي البضاعة لينتج الإجمالي النهائي.
  tonPrice      Decimal? @db.Decimal(18, 2)
  shippingCost  Decimal  @db.Decimal(18, 2) @default(0)
  productsTotal Decimal  @db.Decimal(18, 2) @default(0)

  // ─── دعم عدة عملات (JOD/USD) ────────────────────
  // currency: العملة التي أُنشئت بها المعاملة.
  // exchangeRate: سعر الصرف المحفوظ وقت المعاملة (baseCurrency per transactionCurrency).
  // amountInBase: الإجمالي مُحوَّلاً للعملة الأساسية — يُستخدم في التقارير المُجمَّعة.
  currency      String   @default("JOD")
  exchangeRate  Decimal  @db.Decimal(18, 6) @default(1)
  amountInBase  Decimal  @db.Decimal(18, 3) @default(0)

  lines    SimpleOrderLine[]
  payments SimpleOrderPayment[]

  @@unique([tenantId, number])
  @@index([tenantId, status])
  @@index([tenantId, orderDate])
  @@index([tenantId, orderType])
}

// ── دفعات الطلبية (جدول دفعات لكل طلبية بسيطة) ─────────────
// يدعم:
//   - عدة دفعات لنفس الطلبية بطرق دفع مختلفة
//   - حساب تلقائي للمدفوع/المتبقي/الحالة
//   - تتبّع من أدخل الدفعة وفي أي وقت
model SimpleOrderPayment {
  id          String   @id @default(cuid())
  tenantId    String
  orderId     String
  number      Int                                    // رقم الدفعة ضمن نفس الطلبية (1, 2, 3 ...)
  amount      Decimal  @db.Decimal(18, 2)
  method      String   @default("CASH")              // CASH | TRANSFER | CHEQUE | OTHER
  notes       String?
  createdById String?
  createdAt   DateTime @default(now())

  // ─── دعم عدة عملات ────────────────────────────
  currency      String   @default("JOD")
  exchangeRate  Decimal  @db.Decimal(18, 6) @default(1)
  amountInBase  Decimal  @db.Decimal(18, 3) @default(0)

  order SimpleOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
  @@index([tenantId, createdAt])
}

model SimpleOrderLine {
  id          String   @id @default(cuid())
  orderId     String
  itemId      String?            // ربط بالمخزون (اختياري)
  productName String             // نص حر
  size        String?            // الحجم
  quantity    Decimal  @db.Decimal(18, 4)
  unitPrice   Decimal  @db.Decimal(18, 2)
  lineTotal   Decimal  @db.Decimal(18, 2)

  // ─── حقول جديدة للسطر ───
  // unit: PCS/CTN/TON — يحدّد وحدة الكمية.
  // tonPrice: عند وحدة TON نستخدم tonPrice × quantity كـ lineTotal.
  unit        String?
  tonPrice    Decimal? @db.Decimal(18, 2)

  order SimpleOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([itemId])
}

// ═══════════════════════════════════════════════════════════════════════════
// FIFO Costing (feature) — دفعات شراء + توزيع تكلفة البيع + إعدادات المستأجر
// إضافي بالكامل، لا يمس أي بيانات موجودة.
// ═══════════════════════════════════════════════════════════════════════════

// دفعة شراء (Purchase Batch) — تُنشأ عند كل استلام مادة
model PurchaseBatch {
  id             String   @id @default(cuid())
  tenantId       String
  itemId         String
  batchNumber    String?              // مرجع اختياري (رقم الفاتورة/التشغيلة)
  purchaseDate   DateTime @default(now())
  quantity       Decimal  @db.Decimal(18, 4)   // الكمية الأصلية
  remaining      Decimal  @db.Decimal(18, 4)   // ما تبقى بعد استهلاك FIFO
  unitCost       Decimal  @db.Decimal(18, 4)   // سعر الوحدة
  currency       String   @default("JOD")
  sourceType     String?              // RECEIPT | MANUAL | TRANSFER_IN | PRODUCTION
  sourceRefId    String?              // ربط بـ StockReceipt.id مثلاً
  supplierId     String?
  createdById    String?
  createdAt      DateTime @default(now())

  allocations SaleCostAllocation[]

  @@index([tenantId, itemId, purchaseDate])
  @@index([itemId, remaining])
  @@index([sourceType, sourceRefId])
}

// توزيع تكلفة عملية بيع على دفعات الشراء (سجل دائم لضمان ثبات الأرباح)
model SaleCostAllocation {
  id             String   @id @default(cuid())
  tenantId       String
  saleOrderId    String              // SimpleOrder.id
  saleLineId     String?             // SimpleOrderLine.id (اختياري)
  itemId         String
  batchId        String
  quantity       Decimal  @db.Decimal(18, 4)
  unitCost       Decimal  @db.Decimal(18, 4)
  totalCost      Decimal  @db.Decimal(18, 4)
  method         String   @default("FIFO")   // FIFO | AVG | LIFO (مستقبلاً)
  createdAt      DateTime @default(now())

  batch PurchaseBatch @relation(fields: [batchId], references: [id])

  @@index([tenantId, saleOrderId])
  @@index([saleOrderId])
  @@index([saleLineId])
  @@index([batchId])
  @@index([itemId])
}

// إعدادات المستأجر — الأسلوب الحسابي (FIFO افتراضي، قابل للتوسع)
model TenantSetting {
  id                    String   @id @default(cuid())
  tenantId              String   @unique
  costingMethod         String   @default("FIFO")  // FIFO | AVG | LIFO
  costingCurrency       String   @default("JOD")

  // ─── إعدادات الرواتب / الضمان الاجتماعي ─────────
  // BASIC              → الضمان على الراتب الأساسي فقط (افتراضي)
  // BASIC_PLUS_TRANSPORT → الأساسي + بدل المواصلات
  // GROSS              → إجمالي الراتب (أساسي + مواصلات + إضافي)
  socialSecurityBasis   String   @default("BASIC")
  // ملاحظة: Prisma يقبل numeric literals بشكل قياسي، ونسمّي القيم بالكسر العشري.
  employeeSSRate        Decimal  @db.Decimal(6, 4) @default(0.075)   // 7.5%
  companySSRate         Decimal  @db.Decimal(6, 4) @default(0.1425)  // 14.25%

  // ─── العملة الأساسية للنظام (JOD | USD) ─────────
  baseCurrency          String   @default("JOD")

  updatedById           String?
  updatedAt             DateTime @updatedAt
  createdAt             DateTime @default(now())
}
