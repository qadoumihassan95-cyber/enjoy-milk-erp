# =============================================================================
# Production Environment Variables
# Copy to .env.prod and fill all values
# =============================================================================

# ─── Database ───
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_RANDOM_PASSWORD
POSTGRES_DB=enjoymilk

# ─── JWT secrets — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))" ───
JWT_SECRET=CHANGE_ME_TO_64_CHARS_RANDOM_HEX_STRING
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_64_CHARS_RANDOM_HEX_STRING
JWT_EXPIRES_IN=15m

# ─── URLs ───
APP_URL=https://yourapp.example.com
NEXT_PUBLIC_API_URL=https://yourapp.example.com/api

# ─── Ports (host) ───
API_PORT=3001
WEB_PORT=3000

# ─── Telegram (optional) ───
TELEGRAM_BOT_TOKEN=
